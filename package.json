			"apps/*",
			"packages/*"
		],
		"catalog": {
			"convex": "^1.29.3",
			"better-auth": "1.3.34",
			"@better-auth/expo": "1.3.34",
			"@convex-dev/better-auth": "^0.9.7",
			"@types/node": "^24.10.1",
			"typescript": "~5.9.3",
			"react": "19.1.0",
			"react-dom": "19.1.0",
			"@types/react": "~19.1.17",
