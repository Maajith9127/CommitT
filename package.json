{
  "name": "mono",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "convex": "^1.27.0",
      "better-auth": "1.3.27",
      "@convex-dev/better-auth": "^0.9.1",
      "@types/node": "^22.13.13",
      "typescript": "^5.8.3"
    }
  },
  "scripts": {
    "check": "biome check --write .",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @mono/backend dev",
    "dev:setup": "turbo -F @mono/backend dev:setup",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.9.6",
    "typescript": "^5.9.3",
    "expo": "~54.0.13",
    "react": "19.1.0",
    "react-native": "0.81.4"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "@biomejs/biome": "2.2.6",
    "ultracite": "5.6.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.2.18",
  "version": "1.0.0"
}
