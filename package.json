{
	"name": "mono",
	"private": true,
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"convex": "^1.29.3",
			"better-auth": "1.3.27",
			"@convex-dev/better-auth": "^0.9.7",
			"@types/node": "^24.10.1",
			"typescript": "~5.9.3"
		}
	},
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @mono/backend dev",
		"dev:setup": "turbo -F @mono/backend dev:setup"
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"turbo": "^2.6.1"
