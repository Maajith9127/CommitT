{
  "name": "commit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.3",
      "zod": "^4.3.2",
      "convex": "^1.31.2",
      "better-auth": "^1.4.10",
      "@convex-dev/better-auth": "^0.10.9",
      "@better-auth/expo": "^1.4.10",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "typescript": "^5.9.3",
      "@t3-oss/env-core": "^0.13.10",
      "@types/node": "^25.0.3",
      "@types/react": "19.2.7"
    }
  },
  "type": "module",
  "scripts": {
    "check": "oxlint && oxfmt --write",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @commit/backend dev",
    "dev:setup": "turbo -F @commit/backend dev:setup"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@commit/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "turbo": "^2.7.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
