{
	"name": "@mono/monitoring-extension",
	"description": "Browser extension for monitoring",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"check-types": "tsc --noEmit",
		"lint": "biome check",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"devDependencies": {
		"@types/chrome": "^0.0.312",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@wxt-dev/module-react": "^1.1.3",
		"typescript": "catalog:",
		"wxt": "^0.20.6"
	}
}
